rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /profiles/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /workouts/{workout} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if false;
    }

    match /workout_plans/{plan} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if false;
    }

    match /structured_workouts/{doc} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if false;
    }

    match /personal_records/{record} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if false;
    }

    match /volume_history/{entry} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if false;
    }

    match /shared_plans/{plan} {
      allow read:   if request.auth != null && (
        request.auth.uid == resource.data.sharedWith ||
        resource.data.shareMethod == 'qr'
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.sharedBy;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.sharedWith ||
        (resource.data.shareMethod == 'qr' &&
         resource.data.status == 'pending' &&
         request.resource.data.status == 'claimed' &&
         request.resource.data.claimedBy == request.auth.uid)
      );
      allow delete: if false;
    }

  }
}
